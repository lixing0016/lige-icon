#!name=Loon 图标包每日更新提醒
#!desc=每 24 小时检查一次图标包地址，并通过通知打开 Loon 的订阅资源更新动作。由于 Loon 脚本 API 没有静默更新资源的接口，所以需要点击通知触发更新。
#!author=Codex
#!homepage=https://nsloon.app/docs/Plugin/
#!icon=arrow.clockwise.icloud.system
#!system=iOS,iPadOS
#!loon_version=3.2.1(733)
#!tag=图标,自动化

[Argument]
cron = input,"0 8 * * *",tag=执行时间,desc=Cron 表达式。默认每天 08:00 执行一次。
iconset = input,"",tag=图标包链接,desc=可选。可填一个或多个远程图标包链接；多个链接建议用竖线 | 分隔，也支持换行、英文逗号或分号。
action = select,"update-all","import-iconset",tag=点击通知后的动作,desc=update-all 更新所有订阅资源；import-iconset 打开图标包导入链接。
notifyAlways = switch,true,tag=每次都通知,desc=关闭后，仅在图标包变化或检测失败时通知。

[Script]
cron "{cron}" script-path=https://github.com/lige47/lige_icon/raw/refs/heads/main/Plugin/loon-iconpack-auto-update.js,tag=图标包每日更新提醒,timeout=30,argument=iconset={iconset}&action={action}&notifyAlways={notifyAlways}
